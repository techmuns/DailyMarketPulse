# Frontend audio mode. When set to "premium" the UI tries the
# Cloudflare Worker /api/tts endpoint first and falls back to the
# browser Web Speech API on any failure. Default is "browser".
VITE_AUDIO_MODE=browser

# --- Cloudflare Worker secrets (set via `wrangler secret put`) ---
# TTS_PROVIDER=openai|google|elevenlabs   # default: openai
# TTS_API_KEY=...                          # required for premium audio
